{
  "name": "mcp-test-generator",
  "version": "1.0.2",
  "description": "MCP server that generates test cases for TypeScript, JavaScript, Python, and Java projects. Use with Cursor, Claude Desktop, or any MCP client.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-test-generator": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "test-generator",
    "jest",
    "pytest",
    "vitest",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ranjats/mcp-test-generator.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "glob": "^10.3.10",
    "typescript": "^5.3.3",
    "ts-morph": "^21.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0"
  }
}